// type -- 1.2 multilevel inheritance
class vehile{
    public:
    void start(){
        cout<<"vehicle starts"<<"\n";
    }
};

class car : public vehile{
    public:
    void drive(){
        cout<<"car is running"<<"\n";
    }
};

class speedometer : public car{
    public:
    void speed(){
        cout<<"car is running at 60km/h"<<"\n";
    }
};

