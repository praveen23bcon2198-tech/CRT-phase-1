// type -- 1.4 hierarchical inheritance

class vehicle{
    public:
    void start(){
        cout<<"vehicle starts"<<"\n";
    }
};

class car : public vehicle{
    public:
    void drive(){
        cout<<"car is running"<<"\n";
    }
};

class bike : public vehicle{
    public:
    void ride(){
        cout<<"bike is running"<<"\n";
    }
};

int main(){
    car obj1;
    obj1.start();
    obj1.drive();
    bike obj2;
    obj2.start();
    obj2.ride();
    return 0;
}

// type -- 1.3 multiple inheritance

class parent1{
    public:
    void giveMeMoney(){
        cout<<"mummy paisa do mujhe"<<"\n";
    }
};

class parent2{
    public:
    void giveMeMoney(){
        cout<<"papa paisa do mujhe"<<"\n";
    }
};

class child : public parent1, public parent2{

};

int main(){
    child obj1;
    // obj1.giveMeMoney(); // This will cause ambiguity error
    obj1.parent1::giveMeMoney(); // Resolving ambiguity by specifying the parent class
    obj1.parent2::giveMeMoney(); // Resolving ambiguity by specifying the parent class
    return 0;
}

