#include<iostream>
using namespace std;

class bankAccount{
    private:
    int balance;

    public:
    void setbalance(int amount){
        if(amount >= 0) balance = amount;
        else cout<<"enter a valid number...";
    }
    public:
    int getbalance(){  //ye hmesha koi n koi value return krke dega hi dega
        return balance;
    }

};

int main(){
    bankAccount obj1;
    obj1.setbalance(5000);
    obj1.getbalance();
    cout<<obj1.getbalance();
}

