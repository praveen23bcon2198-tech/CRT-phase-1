//linkedlist 
// create, traversal
#include<iostream>
using namespace std;

class node{
    public:
    int data;
    node* next;

    node(int new_data){
        this->data = new_data;
        this->next = nullptr;
    }
};

node* head = nullptr;
void traversal(){
    while(head != nullptr){
        cout << head->data <<" ";
        head = head->next;
    }
}

int main(){
    head = new node(10);
    head->next = new node(20);
    head->next->next = new node(30);
    head->next->next->next = new node(40);
    traversal();

    return 0;
}
